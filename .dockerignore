# Prevent host OS node_modules from overwriting Linux deps in the image
node_modules
npm-debug.log

# Local env and build artifacts (rebuilt inside the image)
.env
.env.*
!.env.example
bin/
tmp/
static/out/

# Git and IDE
.git
.github
.vscode
.idea
.DS_Store

# Templ outputs are regenerated by `templ generate` in the Dockerfile
**/*_templ.go
