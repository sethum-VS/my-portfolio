{
  "name": "my-portfolio",
  "version": "0.1.0",
  "description": "Sethum Methsanda's personal portfolio",
  "scripts": {
    "tailwind": "tailwindcss -i ./static/css/input.css -o ./static/out/output.css",
    "tailwind:watch": "tailwindcss -i ./static/css/input.css -o ./static/out/output.css --watch",
    "tailwind:build": "tailwindcss -i ./static/css/input.css -o ./static/out/output.css --minify",
    "build:ts": "esbuild frontend/src/main.ts --bundle --outfile=static/out/bundle.js",
    "watch:ts": "esbuild frontend/src/main.ts --bundle --outfile=static/out/bundle.js --watch=forever"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.7",
    "esbuild": "^0.20.0",
    "tailwindcss": "^3.4.17"
  }
}
