# Google Cloud (Firestore, GCS, reCAPTCHA Enterprise)
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# Admin access (comma-separated Firebase user emails)
ADMIN_EMAIL=

# Firebase client (login page)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Resume PDF storage
GCP_STORAGE_BUCKET=

# reCAPTCHA Enterprise checkbox key (challenge widget on resume modal)
# Allowed domains must include your production host (e.g. sethum.dev).
RECAPTCHA_SITE_KEY=
# Minimum risk score for score-based keys. Checkbox submissions that pass the
# challenge are accepted even when the score is low or still calibrating.
RECAPTCHA_MIN_SCORE=0.5

# Resend (transactional email with PDF attachment)
RESEND_API_KEY=
EMAIL_FROM=Seth Ummethsanda <cv@yourdomain.com>

# Optional: Vertex AI for README parsing
GOOGLE_GENAI_USE_VERTEXAI=
GOOGLE_CLOUD_LOCATION=

# Supabase Auth Redirect Configurations
SITE_URL=http://localhost:8080
ADDITIONAL_REDIRECT_URL_1=https://sethum.dev/login
ADDITIONAL_REDIRECT_URL_2=http://localhost:8080/login
ADDITIONAL_REDIRECT_URL_3=http://localhost:3000/login
